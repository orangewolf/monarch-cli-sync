# Single Amazon account (backward-compatible)
AMAZON_USERNAME=your@email.com
AMAZON_PASSWORD=your_password
AMAZON_OTP_SECRET_KEY=***

# --- OR: Multiple Amazon accounts (numbered, starting at 1) ---
# Account 1 (also accepted alongside the legacy vars above)
# AMAZON_USERNAME_1=personal@example.com
# AMAZON_PASSWORD_1=your_password
# AMAZON_OTP_SECRET_1=BASE32SECRETKEY
# AMAZON_LABEL_1=personal

# Account 2
# AMAZON_USERNAME_2=work@example.com
# AMAZON_PASSWORD_2=other_password
# AMAZON_LABEL_2=business

# Optional: auto-solve Amazon WAF CAPTCHA challenges via 2captcha (shared across all accounts)
# AMAZON_CAPTCHA_SOLVER=2captcha
# AMAZON_CAPTCHA_API_KEY=***

# Monarch Money credentials
MONARCH_EMAIL=your@email.com
MONARCH_PASSWORD=your_password
MONARCH_MFA_SECRET_KEY=YOURBASE32SECRET
